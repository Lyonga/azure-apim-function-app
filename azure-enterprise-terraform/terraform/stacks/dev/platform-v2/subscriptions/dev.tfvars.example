subscription_id = "00000000-0000-0000-0000-000000000004"

# Demo dev pattern:
# - keep platform-v2 stacks in one existing platform subscription
# - keep workload-v2 stacks in a separate existing nonprod subscription
# - in a fuller enterprise rollout, connectivity/management/identity would
#   usually move to their own dedicated subscriptions
target_subscriptions = {
  platform = {
    management_group_key     = "platform"
    existing_subscription_id = "00000000-0000-0000-0000-000000000004"
    subscription_display_name = "FinServ Platform"
  }
  nonprod_workload = {
    management_group_key     = "nonprod"
    existing_subscription_id = "00000000-0000-0000-0000-000000000003"
    subscription_display_name = "FinServ Nonprod Workloads"
  }
}
